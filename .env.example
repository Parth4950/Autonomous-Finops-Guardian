# AWS credentials — required for connectivity verification (test_aws.py)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Database — required for future backend services (not used by test_aws.py)
DATABASE_URL=

# Gemini — required for AI-generated risk explanations (Risk Assessor agent)
GEMINI_API_KEY=

# Executor — simulation (default) or real AWS execution (future)
EXECUTION_MODE=simulation
